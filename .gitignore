# Secrets / environment
.env
.env.*
!.env.example

# Xcode
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
xcuserdata/
DerivedData/
build/
*.xcuserstate

# Swift Package Manager
.build/
.swiftpm/
Package.resolved

# macOS
.DS_Store
.grepai/

# Neon CLI scratch
.neon

# XcodeGen output (regenerate with: xcodegen generate). The project itself is
# generated, but commit the SHARED SCHEME so Xcode Cloud can discover it (the
# post-clone hook regenerates the rest before building).
Stripie.xcodeproj/*
!Stripie.xcodeproj/xcshareddata
!Stripie.xcodeproj/project.xcworkspace
Stripie.xcodeproj/xcshareddata/*
!Stripie.xcodeproj/xcshareddata/xcschemes
# Also commit the resolved SPM pin: Xcode Cloud disables live package
# resolution for reproducibility, so a fresh clone needs this file already in
# place or `xcodebuild -resolvePackageDependencies` refuses to run at all.
# (xcuserdata under project.xcworkspace stays excluded by the *.xcworkspace/xcuserdata/ rule above.)
Stripie.xcodeproj/project.xcworkspace/*
!Stripie.xcodeproj/project.xcworkspace/xcshareddata
Stripie.xcodeproj/project.xcworkspace/xcshareddata/*
!Stripie.xcodeproj/project.xcworkspace/xcshareddata/swiftpm
Stripie.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/*
!Stripie.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved

# XcodeGen-generated Info.plist
Stripie/Info.plist
